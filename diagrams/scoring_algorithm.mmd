sequenceDiagram
    participant main
    participant load_songs
    participant recommend_songs
    participant Recommender
    participant score_song

    main->>load_songs: load_songs("data/songs.csv")
    load_songs-->>main: List[Dict] (18 songs)

    main->>recommend_songs: recommend_songs(user_prefs, songs, k=5)

    Note over recommend_songs: Build UserProfile from user_prefs dict
    Note over recommend_songs: Convert dicts → Song objects

    recommend_songs->>Recommender: Recommender(songs)
    recommend_songs->>Recommender: recommend(user, k=5)

    loop For each song in catalog
        Recommender->>score_song: score_song(user, song)
        Note over score_song: genre + mood + audio features
        score_song-->>Recommender: float score (0.0 – 1.0)
    end

    Note over Recommender: Sort by score descending → top k

    Recommender-->>recommend_songs: List[Song] (top k)

    loop For each top song
        recommend_songs->>Recommender: explain_recommendation(user, song)
        Recommender-->>recommend_songs: explanation string
    end

    recommend_songs-->>main: [(song_dict, score, explanation)]

    Note over main: Print title, score, and explanation for each result